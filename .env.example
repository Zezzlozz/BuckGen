# =============================================================================
# BuckGen — Environment Configuration
# Copy this file to .env and fill in your values.
# For production, encrypt sensitive values with `python -m app.encrypt_env`
# and store in .env.encrypted instead.
# =============================================================================

# --- Seed Phrase (12 or 24 words BIP39) ------------------------------------
# Plain text (dev only):
# SEED_PHRASE="word1 word2 word3 ... word12"
#
# Encrypted (production):
#   Run:  python -c "from app.utils.crypto import encrypt_env; print(encrypt_env('your seed phrase', 'your password'))"
#   Then set:
# SEED_PHRASE="buck_enc:<payload>"
# BUCK_ENC_PASSWORD="your password"

# --- 1inch API Key (required for swap execution) ----------------------------
# Create at: https://business.1inch.com/portal/applications
INCH_API_KEY=""

# --- GitHub Token (optional - raises rate limit from 60/hr to 5000/hr) ------
# Create at: https://github.com/settings/tokens (no permissions needed)
GITHUB_TOKEN=""

# --- RPC Endpoints (publicnode.com free tier, no API key needed) -----------
ETH_RPC_URL="https://ethereum.publicnode.com"
BASE_RPC_URL="https://base.publicnode.com"
ARBITRUM_RPC_URL="https://arbitrum.publicnode.com"
POLYGON_RPC_URL="https://polygon-bor.publicnode.com"
BSC_RPC_URL="https://bsc.publicnode.com"
# Optional: swap in your own Infura/Alchemy/Ankr keys for reliability:
# ETH_RPC_URL="https://mainnet.infura.io/v3/YOUR_KEY"

# --- Exchange API Keys (READ-ONLY permissions only) ------------------------
BINANCE_API_KEY=""
BINANCE_SECRET=""

# --- Telegram Alerts (optional) -------------------------------------------
# Create a bot via @BotFather, get token & your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- Budget Controls -------------------------------------------------------
DAILY_GAS_CAP_EUR="5.0"
STOP_LOSS_EUR="20.0"

# --- Schedules (cron expressions - UTC) ------------------------------------
CRON_BOUNTY_SCAN="0 */2 * * *"    # every 2 hours
CRON_PRICE_CHECK="*/30 * * * *"   # every 30 minutes
CRON_AIRDROP="0 */3 * * *"        # every 3 hours

# --- Database --------------------------------------------------------------
# Default: SQLite file in data/buckgen.db
# For Render: use DATABASE_URL from its PostgreSQL add-on:
# DATABASE_URL="postgresql://user:pass@host:5432/buckgen"
# DATABASE_URL="sqlite:///data/buckgen.db"

# --- LLM (local Ollama) ----------------------------------------------------
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:7b"

# --- Network Timeouts ------------------------------------------------------
HTTP_TIMEOUT="30.0"       # Generic HTTP client timeout (CoinGecko, 1inch, Telegram, etc.)
LLM_TIMEOUT="60.0"        # LLM provider timeout (Ollama)

# --- Live Price Fallbacks (when live fetch fails) --------------------------
EUR_USD_FALLBACK="0.92"   # Fallback EUR/USD rate
ETH_USD_FALLBACK="2000.0" # Fallback ETH/USD price
EXCHANGE_FEES_FALLBACK="0.002"  # Fallback taker fee if live ccxt fetch fails (0.2%)

# --- LLM Cache -------------------------------------------------------------
LLM_CACHE_TTL="1800"      # LLM response cache TTL in seconds (30 min)

# --- Trading Defaults ------------------------------------------------------
SLIPPAGE="0.5"            # Default slippage % for 1inch swaps

# --- Arbitrage Thresholds ---------------------------------------------------
MIN_PROFIT_THRESHOLD_PCT="0.8"        # Min profit % to report an arb opportunity
ARB_RISK_PCT="0.02"                   # Max loss estimate as fraction of capital (2%)
TRADE_RESERVE_PCT="0.05"              # Balance reserve fraction (5%)
CONFIDENCE_THRESHOLD="0.6"            # Min confidence to notify arb ops
MAX_ARB_NOTIFICATIONS="3"             # Max arb ops to notify per run

# --- Gas / RPC -------------------------------------------------------------
GAS_THRESHOLD_ETH="0.0005"            # Min ETH equiv for "has_gas" (per chain)
GAS_LIMIT_TRANSFER="21000"            # Gas limit for simple ETH transfer
GAS_LIMIT_TX="100000"                 # Gas limit for general transactions
GAS_LIMIT_SWAP="200000"               # Fallback gas limit for 1inch swaps

# --- Bounty / ROI Thresholds ------------------------------------------------
ROI_ALERT_THRESHOLD="80.0"            # $/hr ROI to ping you proactively
BOUNTY_SCORE_THRESHOLD="0.6"          # Min LLM score to notify high-value bounty
MIN_BOUNTY_SUBMIT_SCORE="0.7"         # Min score to auto-submit a bounty
MAX_BOUNTY_SUBMISSIONS="3"            # Max submissions per auto-run
MAX_BOUNTY_RESULTS="100"              # Max bounties to fetch per scan
GITCOIN_PER_PAGE="100"                # GitHub API per_page limit

# --- Airdrop / Faucet Thresholds --------------------------------------------
FAUCET_CIRCUIT_BREAKER="5"            # Consecutive failures before skipping faucet
WALLETS_PER_CHAIN="3"                 # Wallets per chain for faucet claiming
MAX_AIRDROP_RESULTS="10"              # Max airdrop opportunities to return
AIRDROP_BASELINE_SCORE="0.3"          # Baseline heuristic airdrop score
AIRDROP_POSITIVE_SIGNAL="0.2"         # Bonus per positive signal match
AIRDROP_NEGATIVE_SIGNAL="0.3"         # Penalty per negative signal match

# --- Budget Cost Estimates (testnet / LLM / faucet ops) --------------------
COST_FAUCET_CLAIM="0.001"             # Estimated EUR cost per faucet claim
COST_LLM_SUBMIT="0.01"                # Estimated EUR cost per LLM submission
COST_TESTNET_TRANSFER="0.001"         # Estimated EUR cost per testnet transfer
COST_TESTNET_DEPLOY="0.002"           # Estimated EUR cost per contract deploy
COST_TESTNET_NFT="0.001"              # Estimated EUR cost per NFT mint

# --- Circuit Breaker / System ----------------------------------------------
CIRCUIT_BREAKER_THRESHOLD="5"         # Consecutive failures before circuit opens
CIRCUIT_BREAKER_RESET_SEC="3600"      # Circuit auto-reset (seconds, 1 hour)
ERROR_WINDOW_SEC="3600"               # Error tracking window (seconds, 1 hour)

# --- LLM Scoring Defaults --------------------------------------------------
LLM_TEMPERATURE="0.1"                 # Default LLM temperature (0.0 = deterministic)
LLM_SCORE_MAX_TOKENS="128"            # Max tokens for LLM scoring responses
HEURISTIC_BASELINE_SCORE="0.5"        # Baseline heuristic bounty score
KEYWORD_BONUS_WEIGHT="0.15"           # Keyword match bonus weight
META_BONUS_WEIGHT="0.1"               # Metadata keyword bonus weight
LARGE_REWARD_BONUS="0.1"              # Score bonus for reward >$100
SMALL_REWARD_BONUS="0.05"             # Score bonus for reward >$10

# --- Wallet Batch Defaults -------------------------------------------------
BATCH_WALLET_COUNT="5"                # Default wallets per batch create
BATCH_WALLET_START_INDEX="10"         # Start index (10+ to avoid hot wallets 0-9)

# --- Debug -----------------------------------------------------------------
DEBUG="false"
